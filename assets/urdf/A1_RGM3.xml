    <exclude body1="base_link" body2="wheel_fr"/>
    <exclude body1="base_link" body2="wheel_rl"/>
    <exclude body1="base_link" body2="wheel_rr"/>

    <exclude body1="steer_fl" body2="wheel_fl"/>
    <exclude body1="steer_fr" body2="wheel_fr"/>
    <exclude body1="steer_rl" body2="wheel_rl"/>
    <exclude body1="steer_rr" body2="wheel_rr"/>

